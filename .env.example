# Vercel CLI production deploy from your machine: `npm run deploy`
# Loads .env and passes --token from VERCEL_TOKEN (preferred) or VERCEL_TOKEN_19_MAR.
# Create token: Vercel → Account Settings → Tokens.
# VERCEL_TOKEN=

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: Backend URL only (where server.ts runs). Not your frontend site URL.
# Name must be exactly VITE_API_URL (Vite only reads VITE_*). Not VERCEL_VITE_API_URL.
# If frontend is www.cintiakimura.eu, set this to e.g. https://api.cintiakimura.eu or https://your-app.onrender.com.
# Example: VITE_API_URL=https://your-backend.onrender.com (no trailing slash). Build-time only.
# VITE_API_URL=

# Open mode: no login gate, no payments. Set both to enable.
# BACKEND: OPEN_MODE_FALLBACK_USER_ID = your Supabase user UUID. Optional: OPEN_MODE_ORIGIN = https://cintiakimura.eu so only that origin gets open mode.
# FRONTEND (build-time): VITE_OPEN_MODE=1 (optional if using OPEN_MODE_ORIGIN; cintiakimura.eu is always open-mode on the client).
# OPEN_MODE_FALLBACK_USER_ID=
# OPEN_MODE_ORIGIN=
# VITE_OPEN_MODE=

# Optional: real Google/GitHub login. Set both (build-time) to use Supabase OAuth instead of one-click demo.
# (No longer required: frontend pulls publishable key from /api/config.)
# ALLOWED_ORIGIN: On the backend, set to your frontend URL (e.g. https://your-app.vercel.app) for CORS.
# ALLOWED_ORIGIN=

# Grok (xAI) — one key for chat + Eve TTS. Get key: https://console.x.ai (enable Chat + TTS or Restrict access OFF).
# Chat: server POST https://api.x.ai/v1/chat/completions (default model grok-4-1-fast-reasoning).
# Read-aloud: server POST https://api.x.ai/v1/tts with voice_id eve (client calls your POST /api/tts proxy).
# Also set XAI_API_KEY if you use that name (either works).
GROK_API_KEY=PLACEHOLDER
# Optional: xAI /v1/tts language code (default en). Missing language can cause HTTP 422 from the API.
# XAI_TTS_LANGUAGE=en
# Optional override for /v1/chat/completions model only (default grok-4-1-fast-reasoning):
# GROK_MODEL=grok-4-1-fast-reasoning
# Voice Agent WebSocket: same key; ephemeral token via POST /api/realtime/token.

# Builder.io Visual Copilot — UI/design code generation from prompts. Key from Builder.io dashboard → API keys.
BUILDER_PRIVATE_KEY=PLACEHOLDER
# Free tier: UI generations per user per day (default 10). Pro = unlimited.
# BUILDER_GENERATION_FREE_DAILY_LIMIT=10

# Free tier: max projects per user (default 3). Backend enforces on POST /api/users/:userId/projects.
# FREE_PROJECT_LIMIT=3
# Free tier: Grok chats per user per day (default 10). Pro = unlimited. Stored in Supabase users.grok_calls_today.
# FREE_GROK_DAILY_LIMIT=10

# kyn Platform Secrets - Add to .env
FIREBASE_PROJECT_ID=PLACEHOLDER
GITHUB_CLIENT_ID=PLACEHOLDER
GITHUB_CLIENT_SECRET=PLACEHOLDER
# Backend + frontend auth primitives for Supabase.
# - Frontend (client OAuth/session validation) uses: SUPABASE_PUBLISHABLE_KEY
# - Backend/admin (RLS bypass) uses: SUPABASE_SECRET_KEY
SUPABASE_URL=PLACEHOLDER
SUPABASE_PUBLISHABLE_KEY=PLACEHOLDER
SUPABASE_SECRET_KEY=PLACEHOLDER
STRIPE_SECRET_KEY=PLACEHOLDER
STRIPE_PUBLIC_KEY=PLACEHOLDER
# Pro €19.90/mo — set STRIPE_PRO_PRICE_ID or STRIPE_KING_PRO_PRICE_ID to your Stripe Price ID. Webhook sets is_pro.
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_KING_PRO_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Backend-first (optional) ---
# Ignore browser x-grok-api-key / x-builder-private-key; use only host env for Grok + Builder (recommended for production).
# STRICT_SERVER_API_KEYS=1
#
# Optional Vercel REST: show project + latest deployment in GET /api/integrations/summary (Settings → Refresh env check).
# Create token: Vercel → Account Settings → Tokens. Project ID: Project → Settings → General.
# VERCEL_ACCESS_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# --- Multi-agent (Code Agent → Deploy Agent) — server-side only ---
# Code Agent commits to GitHub via Contents API (classic PAT with repo scope).
# GITHUB_TOKEN=
# GITHUB_AGENT_OWNER=your-org-or-user
# GITHUB_AGENT_REPO=your-repo
# GITHUB_AGENT_BRANCH=main
#
# Deploy Agent: either a Vercel Deploy Hook (preview) or REST API.
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
# Or: VERCEL_ACCESS_TOKEN + VERCEL_PROJECT_ID (and optional VERCEL_TEAM_ID) to create a GitHub-linked preview deployment.
#
# Optional: heavier model for the code pipeline (defaults to GROK_MODEL / fast model).
# GROK_CODE_AGENT_MODEL=grok-3
