# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: Backend URL only (where server.ts runs). Not your frontend site URL.
# Name must be exactly VITE_API_URL (Vite only reads VITE_*). Not VERCEL_VITE_API_URL.
# If frontend is www.cintiakimura.eu, set this to e.g. https://api.cintiakimura.eu or https://your-app.onrender.com.
# Example: VITE_API_URL=https://your-backend.onrender.com (no trailing slash). Build-time only.
# VITE_API_URL=

# Open mode: no login gate, no payments. Set both to enable.
# BACKEND: OPEN_MODE_FALLBACK_USER_ID = your Supabase user UUID. Optional: OPEN_MODE_ORIGIN = https://cintiakimura.eu so only that origin gets open mode.
# FRONTEND (build-time): VITE_OPEN_MODE=1 (optional if using OPEN_MODE_ORIGIN; cintiakimura.eu is always open-mode on the client).
# OPEN_MODE_FALLBACK_USER_ID=
# OPEN_MODE_ORIGIN=
# VITE_OPEN_MODE=

# Optional: real Google/GitHub login. Set both (build-time) to use Supabase OAuth instead of one-click demo.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ALLOWED_ORIGIN: On the backend, set to your frontend URL (e.g. https://your-app.vercel.app) for CORS.
# ALLOWED_ORIGIN=

# Grok (xAI) — sole AI agent for the builder (chat, code, create). Get key: https://console.x.ai
GROK_API_KEY=PLACEHOLDER
# Grok model: default grok-4-1-fast. Optional override:
# GROK_MODEL=grok-4-1-fast

# Builder.io Visual Copilot — UI/design code generation from prompts. Key from Builder.io dashboard → API keys.
BUILDER_PRIVATE_KEY=PLACEHOLDER
# Free tier: UI generations per user per day (default 10). Pro = unlimited.
# BUILDER_GENERATION_FREE_DAILY_LIMIT=10

# Free tier: max projects per user (default 3). Backend enforces on POST /api/users/:userId/projects.
# FREE_PROJECT_LIMIT=3
# Free tier: Grok chats per user per day (default 10). Pro = unlimited. Stored in Supabase users.grok_calls_today.
# FREE_GROK_DAILY_LIMIT=10

# kyn Platform Secrets - Add to .env
FIREBASE_PROJECT_ID=PLACEHOLDER
GITHUB_CLIENT_ID=PLACEHOLDER
GITHUB_CLIENT_SECRET=PLACEHOLDER
# Backend Supabase (server.ts). Use SUPABASE_URL and SUPABASE_ANON_KEY — not SUPABASE_API_URL.
SUPABASE_URL=PLACEHOLDER
SUPABASE_ANON_KEY=PLACEHOLDER
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER
STRIPE_SECRET_KEY=PLACEHOLDER
STRIPE_PUBLIC_KEY=PLACEHOLDER
# Pro €19.90/mo — set STRIPE_PRO_PRICE_ID or STRIPE_KING_PRO_PRICE_ID to your Stripe Price ID. Webhook sets is_pro.
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_KING_PRO_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
