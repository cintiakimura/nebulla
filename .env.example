# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: When frontend is on Netlify (or other static host), set this to your backend URL so login and API work.
# Example: VITE_API_URL=https://your-backend.railway.app (no trailing slash). Build-time only; set in Netlify build env.
# VITE_API_URL=

# Optional: real Google/GitHub login. Set both (build-time) to use Supabase OAuth instead of one-click demo.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ALLOWED_ORIGIN: On the backend (e.g. Railway), set to your frontend URL (e.g. https://your-app.netlify.app) for CORS.
# ALLOWED_ORIGIN=

# Grok (xAI) — sole AI agent for the builder (chat, code, create). Get key: https://console.x.ai
GROK_API_KEY=PLACEHOLDER
# Optional: Grok model (default grok-3-latest). e.g. grok-4-1-fast-reasoning
# GROK_MODEL=grok-3-latest

# kyn Platform Secrets - Add to .env
FIREBASE_PROJECT_ID=PLACEHOLDER
GITHUB_CLIENT_ID=PLACEHOLDER
GITHUB_CLIENT_SECRET=PLACEHOLDER
NETLIFY_CLIENT_ID=PLACEHOLDER
SUPABASE_URL=PLACEHOLDER
SUPABASE_ANON_KEY=PLACEHOLDER
STRIPE_SECRET_KEY=PLACEHOLDER
STRIPE_PUBLIC_KEY=PLACEHOLDER
STRIPE_PROTOTYPE_PRICE_ID=price_xxx
STRIPE_KING_PRO_PRICE_ID=price_xxx
