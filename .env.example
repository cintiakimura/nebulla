# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: When frontend is on a static host (e.g. Vercel), set this to your backend URL so login and API work.
# Example: VITE_API_URL=https://your-backend.railway.app (no trailing slash). Build-time only.
# VITE_API_URL=

# Optional: real Google/GitHub login. Set both (build-time) to use Supabase OAuth instead of one-click demo.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ALLOWED_ORIGIN: On the backend (e.g. Railway), set to your frontend URL (e.g. https://your-app.vercel.app) for CORS.
# ALLOWED_ORIGIN=

# Grok (xAI) — sole AI agent for the builder (chat, code, create). Get key: https://console.x.ai
GROK_API_KEY=PLACEHOLDER
# Grok model: default grok-4-1-fast-reasoning (reasoning mode). Optional override:
# GROK_MODEL=grok-4-1-fast-reasoning

# Builder.io Visual Copilot — UI/design code generation from prompts. Key from Builder.io dashboard → API keys.
BUILDER_PRIVATE_KEY=PLACEHOLDER
# Free tier: UI generations per user per day (default 10). Pro = unlimited.
# BUILDER_GENERATION_FREE_DAILY_LIMIT=10

# Free tier: max projects per user (default 3). Backend enforces on POST /api/users/:userId/projects.
# FREE_PROJECT_LIMIT=3

# kyn Platform Secrets - Add to .env
FIREBASE_PROJECT_ID=PLACEHOLDER
GITHUB_CLIENT_ID=PLACEHOLDER
GITHUB_CLIENT_SECRET=PLACEHOLDER
SUPABASE_URL=PLACEHOLDER
SUPABASE_ANON_KEY=PLACEHOLDER
STRIPE_SECRET_KEY=PLACEHOLDER
STRIPE_PUBLIC_KEY=PLACEHOLDER
# Use Price IDs (price_xxx), not Product IDs (prod_xxx). In Stripe: Product → Pricing → copy price ID.
STRIPE_PROTOTYPE_PRICE_ID=price_xxx
STRIPE_KING_PRO_PRICE_ID=price_xxx
